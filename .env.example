SERVER_PORT=8080

# MongoDB (local Docker default)
MONGODB_URL=mongodb://localhost:27017/?directConnection=true

# PostgreSQL DSN (local Docker default)
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/tzone?sslmode=disable

# Supabase hosted API (optional)
SUPABASE_API_URL=
SUPABASE_KEY=

# Hosted examples:
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?appName=tzone
# SUPABASE_API_URL=https://your-project.supabase.co

# Backward-compatible legacy names (still supported, but deprecated):
# MONGODB_ATLAS_URL=
# SUPABASE_URL=
